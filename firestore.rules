rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // users/{userId}: solo el propietario. Contiene familyId que apunta a la familia.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Función auxiliar: comprueba si el usuario está en la lista de miembros de la familia
    function isMemberOfFamily(familyId) {
      let family = get(/databases/$(database)/documents/families/$(familyId));
      return request.auth != null &&
             request.auth.uid in family.data.members;
    }

    // Documento de la familia (misma lógica que te funcionaba + get para QR join)
    match /families/{familyId} {
      // Quien escanea QR puede leer el doc si existe (no puede listar la colección).
      allow get: if request.auth != null && resource.exists;
      allow list: if false;

      allow read, delete: if request.auth != null &&
        request.auth.uid in resource.data.members;
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.members ||
        request.auth.uid in request.resource.data.members
      );
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.members;
    }

    match /families/{familyId}/{document=**} {
      allow read, write: if isMemberOfFamily(familyId);
    }
  }
}
