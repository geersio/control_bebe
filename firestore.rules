rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // users/{userId}: solo el propietario. Contiene familyId que apunta a la familia.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Lista de UIDs miembros (si falta el campo en docs antiguos, se trata como vacía).
    function familyMemberIds(data) {
      return ('members' in data && data.members is list) ? data.members : [];
    }

    // Función auxiliar: comprueba si el usuario está en la lista de miembros de la familia
    function isMemberOfFamily(familyId) {
      let family = get(/databases/$(database)/documents/families/$(familyId));
      return request.auth != null &&
             request.auth.uid in familyMemberIds(family.data);
    }

    // Unión por QR: solo puede cambiar `members`, añadir exactamente un uid (el propio),
    // sin quitar a nadie (hasAll + size).
    function isJoiningViaMembersArrayUnion() {
      let before = familyMemberIds(resource.data);
      let after = familyMemberIds(request.resource.data);
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
             after.size() == before.size() + 1 &&
             after.hasAll(before) &&
             request.auth.uid in after;
    }

    // Documento de la familia (misma lógica que te funcionaba + get para QR join)
    match /families/{familyId} {
      // Get individual: solo hace falta estar logueado. NO exigir resource.exists:
      // si el doc no existe, con "exists" en la regla Firestore devuelve permission-denied
      // y el cliente nunca puede comprobar !snap.exists (p. ej. QR mal o otro proyecto).
      allow get: if request.auth != null;
      allow list: if false;

      allow read, delete: if request.auth != null &&
        request.auth.uid in familyMemberIds(resource.data);
      allow update: if request.auth != null && (
        request.auth.uid in familyMemberIds(resource.data) ||
        isJoiningViaMembersArrayUnion()
      );
      allow create: if request.auth != null &&
        request.auth.uid in familyMemberIds(request.resource.data);
    }

    match /families/{familyId}/{document=**} {
      allow read, write: if isMemberOfFamily(familyId);
    }
  }
}
