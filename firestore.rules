rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // users/{userId}: solo el propietario. Contiene familyId que apunta a la familia.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Función auxiliar: comprueba si el usuario está en la lista de miembros de la familia
    function isMemberOfFamily(familyId) {
      let family = get(/databases/$(database)/documents/families/$(familyId));
      return request.auth != null &&
             family.exists &&
             request.auth.uid in family.data.members;
    }
    
    // Documento de la familia: solo miembros pueden leer/escribir
    // update: miembros existentes O usuario añadiéndose (join vía QR)
    match /families/{familyId} {
      allow read, delete: if request.auth != null && 
        request.auth.uid in resource.data.members;
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.members ||
        request.auth.uid in request.resource.data.members
      );
      // En create, el creador debe incluirse en members
      allow create: if request.auth != null && 
        request.auth.uid in request.resource.data.members;
    }
    
    // Subcolecciones bajo families/{familyId}/* (ej: records, babyProfiles, etc.)
    match /families/{familyId}/{document=**} {
      allow read, write: if isMemberOfFamily(familyId);
    }
  }
}
